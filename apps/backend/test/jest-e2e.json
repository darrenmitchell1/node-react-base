{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "extensionsToTreatAsEsm": [".js", ".jsx", ".ts", ".tsx"],
  "transform": {
    "^.+\\.(c|m)?(j|t)sx?$": ["ts-jest", { "useESM": true }]
  },
  "setupFiles": ["dotenv/config"],
  "globals": {
    "process.env.NODE_ENV": "test"
  }
}
