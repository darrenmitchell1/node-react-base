{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":     "vite build && tsc --emitDeclarationOnly",
    "dev":       "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react":     "^18",
    "react-dom": "^18"
  },
  "dependencies": {
    "@repo/types": "*"
  },
  "devDependencies": {
    "@types/react":         "^18",
    "@vitejs/plugin-react": "^4",
    "typescript":           "*",
    "vite":                 "^5"
  }
}
